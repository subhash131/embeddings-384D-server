{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",      
    "moduleResolution": "NodeNext",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "types": ["node"],           
    "paths": {
      "@workspace/backend/*": ["../../packages/backend/convex/*"],
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*"],      
  "exclude": ["node_modules", "dist"]
}